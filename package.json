{
  "name": "akyuu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter @akyuu/web dev",
    "dev:api": "pnpm --filter @akyuu/api dev",
    "dev:scheduler": "pnpm --filter @akyuu/scheduler dev",
    "dev:worker": "pnpm --filter @akyuu/worker dev",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @akyuu/infra-db migrate",
    "db:seed": "pnpm --filter @akyuu/infra-db seed",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.2.0",
    "globals": "17.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  }
}
